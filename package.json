{
	"name": "@kitschpatrol/create-project",
	"version": "1.5.2",
	"description": "Kitschpatrol's TypeScript project templates.",
	"keywords": [
		"cli",
		"template",
		"bingo"
	],
	"homepage": "https://github.com/kitschpatrol/create-project",
	"bugs": "https://github.com/kitschpatrol/create-project/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/create-project.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": false,
	"type": "module",
	"bin": "dist/index.js",
	"files": [
		"dist",
		"templates",
		"!**/node_modules"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"fix": "ksc fix --skip mdat && mdat readme.md",
		"lint": "ksc lint --skip mdat && mdat check readme.md",
		"release": "bumpp --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') pnpm publish",
		"test": "vitest run",
		"update-templates": "for dir in ./templates/*; do taze -w --cwd \"$dir\"; done",
		"update-templates-major": "for dir in ./templates/*; do taze major -w --cwd \"$dir\" --exclude @types/node,typescript,zod,vite; done"
	},
	"dependencies": {
		"bingo": "^0.9.3",
		"bingo-fs": "^0.5.6",
		"bingo-handlebars": "^0.1.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.6.4",
		"@types/node": "~20.19.41",
		"bumpp": "^11.1.0",
		"mdat": "^2.3.6",
		"shx": "^0.4.0",
		"taze": "^19.14.1",
		"tsdown": "^0.22.2",
		"typescript": "~5.9.3",
		"vitest": "^4.1.8"
	},
	"packageManager": "pnpm@11.5.2",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^22.22.2 || >=24.0.0"
		}
	},
	"publishConfig": {
		"access": "public"
	}
}
