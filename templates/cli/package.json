{
	"name": "{{{github-repository}}}",
	"version": "0.0.0",
	"description": "A {{{type}}} project.",
	"keywords": [
		"cli",
		"npm-package"
	],
	"homepage": "https://github.com/{{{github-owner}}}/{{{github-repository}}}",
	"bugs": "https://github.com/{{{github-owner}}}/{{{github-repository}}}/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/{{{github-owner}}}/{{{github-repository}}}.git"
	},
	"license": "MIT",
	"author": {
		"name": "{{{author-name}}}",
		"email": "{{{author-email}}}",
		"url": "{{{author-url}}}"
	},
	"sideEffects": false,
	"type": "module",
	"bin": {
		"{{{cli-command-name}}}": "dist/index.js"
	},
	"files": [
		"dist/*"
	],
	"scripts": {
		"bench": "vitest bench --run --compare test/benchmarks/baseline.json",
		"bench:baseline": "vitest bench --run --outputJson test/benchmarks/baseline.json",
		"build": "tsdown",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm build && NPM_AUTH_TOKEN=$({{{npm-auth-command}}}) && pnpm publish",
		"test": "vitest run"
	},
	"dependencies": {
		"@types/node": "~20.19.39",
		"@types/yargs": "^17.0.35",
		"lognow": "^0.6.1",
		"yargs": "^18.0.0"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.5.2",
		"bumpp": "^11.0.1",
		"mdat-plugin-cli-help": "^3.0.0",
		"publint": "^0.3.18",
		"shx": "^0.4.0",
		"tsdown": "^0.21.10",
		"typescript": "~6.0.3",
		"vitest": "^4.1.5"
	},
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.18.0"
		}
	}
}
