{
	"name": "{{{github-repository}}}",
	"version": "0.0.0",
	"private": true,
	"description": "A {{{type}}} project.",
	"keywords": [
		"{{{type}}}"
	],
	"homepage": "https://github.com/{{{github-owner}}}/{{{github-repository}}}",
	"bugs": "https://github.com/{{{github-owner}}}/{{{github-repository}}}/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/{{{github-owner}}}/{{{github-repository}}}.git"
	},
	"license": "MIT",
	"author": {
		"name": "{{{author-name}}}",
		"email": "eric@ericmika.com",
		"url": "{{{author-url}}}"
	},
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"bench": "vitest bench --run --compare test/benchmarks/baseline.json",
		"bench:baseline": "vitest bench --run --outputJson test/benchmarks/baseline.json",
		"build": "vite build",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "poptab && vite",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"preview": "poptab && vite preview",
		"release": "bumpp --commit 'Release: %s'",
		"test": "vitest run"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^8.0.0",
		"@types/node": "~20.19.43",
		"bumpp": "^11.1.0",
		"poptab": "^1.1.1",
		"shx": "^0.4.0",
		"typescript": "~6.0.3",
		"vite": "^8.1.2",
		"vite-plugin-mkcert": "~2.1.0",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@11.10.0",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^22.22.2 || >=24.0.0"
		}
	}
}
