{
	"name": "{{{github-repository}}}",
	"version": "0.0.0",
	"private": true,
	"description": "A {{{type}}} project.",
	"keywords": [
		"{{{type}}}"
	],
	"homepage": "https://github.com/{{{github-owner}}}/{{{github-repository}}}",
	"bugs": "https://github.com/{{{github-owner}}}/{{{github-repository}}}/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/{{{github-owner}}}/{{{github-repository}}}.git"
	},
	"license": "MIT",
	"author": {
		"name": "{{{author-name}}}",
		"email": "{{{author-email}}}",
		"url": "{{{author-url}}}"
	},
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"build": "tsx script.ts",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "tsx --watch script.ts",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s'",
		"test": "echo 'No tests configured'"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.6.0",
		"@types/node": "~20.19.41",
		"bumpp": "^11.1.0",
		"shx": "^0.4.0",
		"tsx": "^4.21.0",
		"typescript": "~6.0.3"
	},
	"packageManager": "pnpm@11.1.1",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^22.18.0 || >=24.0.0"
		}
	}
}
