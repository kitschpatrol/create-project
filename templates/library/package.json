{
	"name": "{{{github-repository}}}",
	"version": "0.0.0",
	"description": "A {{{type}}} project.",
	"keywords": [
		"npm-package"
	],
	"homepage": "https://github.com/{{{github-owner}}}/{{{github-repository}}}",
	"bugs": "https://github.com/{{{github-owner}}}/{{{github-repository}}}/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/{{{github-owner}}}/{{{github-repository}}}.git"
	},
	"license": "MIT",
	"author": {
		"name": "{{{author-name}}}",
		"email": "{{{author-email}}}",
		"url": "{{{author-url}}}"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"files": [
		"dist/*"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$({{{npm-auth-command}}}) && pnpm publish",
		"test": "vitest run"
	},
	"dependencies": {
		"@types/node": "~20.19.37",
		"lognow": "^0.5.2"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@kitschpatrol/shared-config": "^6.0.3",
		"bumpp": "^11.0.1",
		"publint": "^0.3.18",
		"tsdown": "^0.21.4",
		"typescript": "~5.9.3",
		"vitest": "^4.1.0"
	},
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=20.19.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.18.0"
		}
	}
}
