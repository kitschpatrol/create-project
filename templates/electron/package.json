{
	"name": "{{{github-repository}}}",
	"version": "0.0.0",
	"private": true,
	"description": "An {{{type}}} project.",
	"keywords": [
		"{{{type}}}"
	],
	"homepage": "https://github.com/{{{github-owner}}}/{{{github-repository}}}",
	"bugs": "https://github.com/{{{github-owner}}}/{{{github-repository}}}/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/{{{github-owner}}}/{{{github-repository}}}.git"
	},
	"license": "MIT",
	"author": {
		"name": "{{{author-name}}}",
		"email": "{{{author-email}}}",
		"url": "{{{author-url}}}"
	},
	"sideEffects": false,
	"type": "module",
	"main": "dist-electron/main.js",
	"scripts": {
		"bench": "vitest bench --run --compare test/benchmarks/baseline.json",
		"bench:baseline": "vitest bench --run --outputJson test/benchmarks/baseline.json",
		"build": "vite build && electron-builder",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "vite",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"release": "bumpp --commit 'Release: %s' && pnpm build && electron-builder build --publish always",
		"test": "vitest run"
	},
	"dependencies": {
		"lognow": "^0.6.2"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^8.0.0",
		"@types/node": "~22.19.21",
		"bumpp": "^11.1.0",
		"electron": "^43.0.0",
		"electron-builder": "^26.15.3",
		"shx": "^0.4.0",
		"typescript": "~6.0.3",
		"vite": "^8.1.2",
		"vite-plugin-electron": "^1.1.0",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@11.10.0",
	"engines": {
		"node": "^22.22.2 || >=24.0.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24.16.0"
		}
	}
}
